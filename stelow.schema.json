{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/renatocaliari/stelow/main/stelow.schema.json",
  "title": "Cali Product Workflow Tracking",
  "description": "Schema for tracking product workflow execution and status",
  "type": "object",
  "required": ["$schema", "version", "workflows"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "URL to the JSON schema"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$",
      "description": "Schema version"
    },
    "created": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 creation timestamp"
    },
    "updated": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 last update timestamp"
    },
    "workflows": {
      "type": "array",
      "description": "Array of workflow entries",
      "items": {
        "$ref": "#/definitions/workflow"
      }
    }
  },
  "definitions": {
    "workflow": {
      "type": "object",
      "required": ["name", "status", "phases"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Human-readable workflow identifier (e.g., 'feature-login')"
        },
        "slug": {
          "type": "string",
          "description": "[Deprecated] Legacy field, use name instead"
        },
        "description": {
          "type": "string",
          "description": "Brief description of the workflow"
        },
        "status": {
          "type": "string",
          "enum": ["draft", "planning", "approved", "in-progress", "completed", "archived"],
          "description": "Current workflow status"
        },
        "created": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 creation timestamp"
        },
        "updated": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 last update timestamp"
        },
        "phases": {
          "type": "array",
          "description": "Workflow phases (Shape Up stages)",
          "items": {
            "$ref": "#/definitions/phase"
          }
        },
        "stage": {
          "$ref": "#/definitions/stage-state",
          "description": "Unified stage tracking — replaces legacy current-stage.json"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Optional tags for categorization"
        },
        "metadata": {
          "type": "object",
          "description": "Additional workflow metadata"
        }
      }
    },
    "stage-state": {
      "type": "object",
      "required": ["current_stage", "previous_stage", "transitioned_at", "history"],
      "properties": {
        "current_stage": {
          "type": "string",
          "description": "Current stage slug (e.g., 'shape', 'planning')"
        },
        "previous_stage": {
          "type": ["string", "null"],
          "description": "Previous stage slug, or null for first transition"
        },
        "transitioned_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO timestamp of last transition"
        },
        "history": {
          "type": "array",
          "description": "Ordered history of all stage transitions",
          "items": {
            "type": "object",
            "required": ["stage", "entered_at"],
            "properties": {
              "stage": { "type": "string" },
              "entered_at": { "type": "string", "format": "date-time" },
              "exited_at": { "type": ["string", "null"], "format": "date-time" }
            }
          }
        },
        "gates_passed": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Plannotator gates passed by name"
        },
        "supervisor_active": {
          "type": "boolean",
          "description": "Whether supervisor is active in current stage"
        }
      }
    },
    "phase": {
      "type": "object",
      "required": ["id", "name", "status"],
      "properties": {
        "id": {
          "type": "string",
          "enum": ["0-clarify", "1-shape", "2-bet", "3-build", "4-critique", "5-gate"],
          "description": "Phase identifier"
        },
        "name": {
          "type": "string",
          "description": "Human-readable phase name"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "in-progress", "completed", "skipped"],
          "description": "Stage status"
        },
        "started": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 start timestamp"
        },
        "completed": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 completion timestamp"
        },
        "output": {
          "type": "string",
          "description": "Path or reference to phase output artifact"
        },
        "notes": {
          "type": "string",
          "description": "Optional notes for the phase"
        }
      }
    }
  }
}