{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "_comment": "Mutation testing config — scoped to files with meaningful business logic + test coverage",
  "testRunner": "vitest",
  "coverageAnalysis": "all",
  "vitest": {
    "configFile": "vitest.mutate.config.ts",
    "related": false
  },
  "thresholds": {
    "high": 70,
    "low": 50,
    "break": null
  },
  "mutate": [
    "extensions/stelow/modules/file-store.ts",
    "extensions/stelow/adapters/stages-guard.ts"
  ],
  "ignorePatterns": [
    ".opencode",
    ".pi",
    ".stryker-tmp",
    "stryker-reports",
    "cli-agents",
    "docs",
    "scripts",
    "*.md"
  ],
  "reporters": ["clear-text", "html"],
  "htmlReporter": {
    "fileName": "stryker-reports/index.html"
  }
}
